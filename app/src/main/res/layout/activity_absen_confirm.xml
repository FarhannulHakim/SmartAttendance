<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ABSEN MASUK"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Preview Foto Hasil Kamera -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="350dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/img_confirm_result"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Detail Info Otomatis -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tv_confirm_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 Juni 2026"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jam"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tv_confirm_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:15"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lokasi"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tv_confirm_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kampus ABC"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btn_absen_final"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="ABSEN SEKARANG"
        android:backgroundTint="@color/primary"
        app:cornerRadius="10dp"/>

</LinearLayout>